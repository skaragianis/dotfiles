# Ignore local git metadata inside config directories
**/.git
**/.gitignore

# fish's universal-variable store is machine-local state (fish rewrites it at
# runtime, and it holds per-machine fish_user_paths). Never manage it, or Mac
# paths leak onto the Debian VM.
.config/fish/fish_variables

# Ignore Neovim state caches & histories
.config/nvim/undo/
.config/nvim/view/
.config/nvim/shallow/
.config/nvim/**/yankring_history*.txt
.config/nvim/lazyvim.json
.config/nvim/lazy-lock.json
README.md
